#!/bin/csh -f

set inp = "undefined"
if ($#argv == 1) then
  set inp = $1
endif

setenv ICE_MACHINE_MACHNAME conda
setenv ICE_MACHINE_MACHINFO "Local macOS Homebrew setup used for ClimaSeaIce CICE validation"
setenv ICE_MACHINE_ENVNAME homebrew
setenv ICE_MACHINE_ENVINFO "Homebrew gfortran, clang, netcdf-fortran via nf-config"
setenv ICE_MACHINE_MAKE make
setenv ICE_MACHINE_WKDIR /private/tmp/cice-validation/runs
setenv ICE_MACHINE_INPUTDATA /private/tmp/cice-validation/input
setenv ICE_MACHINE_BASELINE /private/tmp/cice-validation/baseline
setenv ICE_MACHINE_SUBMIT " "
setenv ICE_MACHINE_TPNODE 1
setenv ICE_MACHINE_ACCT none
setenv ICE_MACHINE_QUEUE none
setenv ICE_MACHINE_BLDTHRDS 4
setenv ICE_MACHINE_QSTAT " "
